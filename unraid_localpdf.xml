  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled>1760606276</DateInstalled>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="Web Port for Nginx and GUI" Target="8080" Default="8080" Mode="tcp" Description="Port used for LocalPDF's web GUI" Type="Port" Display="always" Required="false" Mask="false">80</Config>
  <TailscaleStateDir/>
