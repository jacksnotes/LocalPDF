<?xml version="1.0"?>
<Container version="2">
  <Name>localpdf</Name>
  <Repository>jacksnotes/localpdf</Repository>
  <Registry>https://hub.docker.com/r/jacksnotes/localpdf/</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/jacksnotes/LocalPDF</Support>
